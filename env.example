# RxVerify Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required)
OPENAI_API_KEY=your-openai-api-key-here

# openFDA API Key (optional — improves rate limit to 240/min, 120k/day per key)
OPENFDA_API_KEY=
# Self-imposed throttles. Defaults stay safely under openFDA's published caps.
OPENFDA_MAX_PER_MINUTE=200
OPENFDA_MAX_PER_DAY=100000

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# Database Settings
CHROMA_PERSIST_DIRECTORY=./chroma_db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Settings
FRONTEND_PORT=8080
BACKEND_URL=http://localhost:8000
